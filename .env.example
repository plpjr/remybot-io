# Kronos Dashboard — environment variables
# Copy to .env.local for development.
# Cloudflare Pages: set in project settings under Environment variables.

# Supabase — required. The anon key is safe to expose (public by design);
# real access control is via Row Level Security policies. Rotating keys
# requires updating env + redeploy (never hardcode in source).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Bot /healthz proxy — required for live health polling via
# functions/api/healthz.ts. Usually the bot's reverse-proxied URL
# (never the direct VPS IP — keep /healthz off the public internet).
# Example: https://bot.example.com/healthz (Tailscale + CF Access)
KRONOS_HEALTHZ_URL=https://your-bot-host/healthz

# Optional: coinbase public ticker for the home-page BTC-price widget
# (already used by functions/api/btc-price.ts — leave blank to use
# the default Coinbase public endpoint).
COINBASE_TICKER_URL=
